generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooler Supabase (port 6543) — utilisé par Vercel/serverless
  url       = env("DATABASE_URL")
  // Connexion directe (port 5432) — utilisé par prisma migrate/db push
  directUrl = env("DIRECT_URL")
}

model Team {
  id             String @id @default(cuid())
  abbr           String @unique
  city           String
  name           String
  slug           String @unique
  conference     String
  division       String
  primaryColor   String
  secondaryColor String
  logoUrl        String?
  founded        Int
  arena          String?
  city_country   String?

  seasons            TeamSeason[]
  playerSeasons      PlayerSeason[]
  homeGames          Game[]          @relation("HomeGames")
  awayGames          Game[]          @relation("AwayGames")
  playoffSeriesTeam1 PlayoffSeries[] @relation("PlayoffTeam1")
  playoffSeriesTeam2 PlayoffSeries[] @relation("PlayoffTeam2")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Player {
  id                 String    @id @default(cuid())
  firstName          String
  lastName           String
  slug               String    @unique
  birthDate          DateTime?
  height             String?
  weight             String?
  position           String?
  country            String?
  draftYear          Int?
  draftPick          Int?
  college            String?
  photoUrl           String?
  photoAttribution   String?
  wikipediaUrlFr     String?
  wikipediaUrlEn     String?
  summaryFr          String?   @db.Text
  summaryEn          String?   @db.Text
  summaryGeneratedAt DateTime?

  seasons PlayerSeason[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerSeason {
  id       String @id @default(cuid())
  playerId String
  teamId   String
  season   String

  gamesPlayed     Int
  minutesPerGame  Float
  pointsPerGame   Float
  reboundsPerGame Float
  assistsPerGame  Float
  stealsPerGame   Float
  blocksPerGame   Float
  fgPct           Float?
  threePtPct      Float?
  ftPct           Float?

  per          Float?
  trueShooting Float?
  usageRate    Float?
  bpm          Float?
  vorp         Float?
  winShares    Float?

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([playerId, season, teamId])
  @@index([season])
  @@index([teamId, season])
}

model TeamSeason {
  id     String @id @default(cuid())
  teamId String
  season String

  wins                   Int
  losses                 Int
  conferenceRank         Int?
  previousConferenceRank Int?
  offRating              Float?
  defRating      Float?
  netRating      Float?
  pace           Float?
  playoffResult  String?
  summaryFr      String? @db.Text

  team Team @relation(fields: [teamId], references: [id])

  @@unique([teamId, season])
  @@index([season])
}

model Game {
  id         String   @id @default(cuid())
  espnId     String   @unique
  homeTeamId String
  awayTeamId String
  gameDate   DateTime
  season     String
  homeScore  Int?
  awayScore  Int?
  status     String   // "scheduled" | "final"

  homeTeam Team @relation("HomeGames", fields: [homeTeamId], references: [id])
  awayTeam Team @relation("AwayGames", fields: [awayTeamId], references: [id])

  @@index([season, status])
  @@index([homeTeamId, season])
  @@index([awayTeamId, season])
}

model PlayoffSeries {
  id              String    @id @default(cuid())
  season          String    // "2025-26"
  conference      String    // "WEST" | "EAST" | "FINALS"
  round           Int       // 1=First Round 2=Conf Semis 3=Conf Finals 4=NBA Finals
  team1Id         String    // top seed (ou west pour la finale)
  team2Id         String    // bottom seed (ou east pour la finale)
  team1Seed       Int?
  team2Seed       Int?
  team1Wins       Int       @default(0)
  team2Wins       Int       @default(0)
  completed       Boolean   @default(false)
  summary         String?   // "OKC wins series 4-3"
  gameNumber      Int       @default(1)
  nextGameDate    DateTime?
  nextGameNetwork String?

  team1 Team @relation("PlayoffTeam1", fields: [team1Id], references: [id])
  team2 Team @relation("PlayoffTeam2", fields: [team2Id], references: [id])

  @@unique([season, conference, round, team1Id, team2Id])
  @@index([season])
}

model SyncLog {
  id             String   @id @default(cuid())
  source         String
  status         String
  itemsProcessed Int
  errors         Json?
  startedAt      DateTime
  completedAt    DateTime
}
