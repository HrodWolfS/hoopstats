# ── Base URL (Vercel / production) ───────────────────────────────────────────
# Ex: https://hoopstats.fr  ou  https://hoopstats.vercel.app
NEXT_PUBLIC_BASE_URL=

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Pooler Transaction Mode (port 6543) — utilisé par l'app / Vercel serverless
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Connexion directe (port 5432) — utilisé par prisma migrate / prisma db push
# Format: postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
DIRECT_URL=

# ── APIs scripts (dev seulement) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
BALLDONTLIE_API_KEY=

# ── n8n cron revalidation ────────────────────────────────────────────────────
REVALIDATE_SECRET=

# ── Analytics (optionnel) ────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
